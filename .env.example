# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Usá una de las dos (según tu dashboard de Supabase):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo servidor. Settings → API Keys → "Secret key" (no la Publishable).
SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URLs de enlaces en correos (invitación / recuperación)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Correos — elegí UNA opción:

# A) SMTP del proveedor del dominio (sin 2FA de Google; recomendado si no podés usar App Password)
# SMTP_HOST=mail.ecolink.com.ar
# SMTP_PORT=587
# SMTP_USER=somos@ecolink.com.ar
# SMTP_PASS=contraseña_del_buzón
# EMAIL_FROM=somos@ecolink.com.ar
# EMAIL_FROM_NAME=App Recolectores Ecolink

# B) Gmail (requiere verificación en 2 pasos + contraseña de aplicación)
# GMAIL_USER=somos@ecolink.com.ar
# GMAIL_APP_PASSWORD=16caracteres
# EMAIL_FROM_NAME=App Recolectores Ecolink

# Sin configurar correo: la app muestra enlaces para copiar manualmente.

# Integración Google Sheets → importación de rutas (Apps Script)
# Generá uno seguro: openssl rand -base64 32
SHEETS_IMPORT_SECRET=genera_un_secreto_largo
