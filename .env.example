# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Usá una de las dos (según tu dashboard de Supabase):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo servidor (Vercel → Environment Variables). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# URLs de correos de invitación / recuperación de contraseña
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opcional: conexión directa Postgres para migraciones locales
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.TU_PROYECTO.supabase.co:5432/postgres
